# Copy to `.env` for local dev (`.env` is gitignored — never commit real secrets).
APP_NAME=CampusEats API
APP_ENV=development

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# REQUIRED. Must be unique and >= 32 bytes (HS256, RFC 7518 §3.2). The app refuses
# to start with a missing/placeholder/short key. Generate one with, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated browser origins allowed to call the API (CORS).
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
