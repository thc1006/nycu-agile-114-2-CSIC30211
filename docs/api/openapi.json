  "components": {
    "schemas": {
      "CreateOrderRequest": {
        "properties": {
          "restaurant": {
            "type": "string",
            "maxLength": 100,
            "minLength": 1,
            "title": "Restaurant"
          },
          "meal": {
            "type": "string",
            "maxLength": 500,
            "minLength": 1,
            "title": "Meal"
          },
          "pickup_location": {
            "type": "string",
            "maxLength": 100,
            "minLength": 1,
            "title": "Pickup Location"
          },
          "expected_time": {
            "type": "string",
            "format": "date-time",
            "title": "Expected Time"
          },
          "delivery_fee": {
            "type": "integer",
            "minimum": 0.0,
            "title": "Delivery Fee"
          }
        },
        "type": "object",
        "required": [
          "restaurant",
          "meal",
          "pickup_location",
          "expected_time",
          "delivery_fee"
        ],
        "title": "CreateOrderRequest"
      },
      "CurrentUserResponse": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "email": {
            "type": "string",
            "format": "email",
            "title": "Email"
          },
          "name": {
            "type": "string",
            "title": "Name"
          }
        },
        "type": "object",
        "required": [
          "id",
          "email",
          "name"
        ],
        "title": "CurrentUserResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "LoginRequest": {
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "title": "Email"
          },
          "password": {
            "type": "string",
            "title": "Password"
          }
        },
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "title": "LoginRequest"
      },
      "OpenOrderResponse": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "restaurant": {
            "type": "string",
            "title": "Restaurant"
          },
          "meal_summary": {
            "type": "string",
            "title": "Meal Summary"
          },
          "pickup_location": {
            "type": "string",
            "title": "Pickup Location"
          },
          "expected_time": {
            "type": "string",
            "format": "date-time",
            "title": "Expected Time"
          },
          "delivery_fee": {
            "type": "integer",
            "title": "Delivery Fee"
          },
          "status": {
            "$ref": "#/components/schemas/OrderStatus"
          }
        },
        "type": "object",
        "required": [
          "id",
          "restaurant",
          "meal_summary",
          "pickup_location",
          "expected_time",
          "delivery_fee",
          "status"
        ],
        "title": "OpenOrderResponse"
      },
      "OrderResponse": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "customer_id": {
            "type": "string",
            "title": "Customer Id"
          },
          "runner_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Runner Id"
          },
          "restaurant": {
            "type": "string",
            "title": "Restaurant"
          },
          "meal": {
            "type": "string",
            "title": "Meal"
          },
          "pickup_location": {
            "type": "string",
            "title": "Pickup Location"
          },
          "expected_time": {
            "type": "string",
            "format": "date-time",
            "title": "Expected Time"
          },
          "delivery_fee": {
            "type": "integer",
            "title": "Delivery Fee"
          },
          "status": {
            "$ref": "#/components/schemas/OrderStatus"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "customer_id",
          "restaurant",
          "meal",
          "pickup_location",
          "expected_time",
          "delivery_fee",
          "status",
          "created_at",
          "updated_at"
        ],
        "title": "OrderResponse"
      },
      "OrderStatus": {
        "type": "string",
        "enum": [
          "OPEN",
          "ACCEPTED",
          "BUYING",
          "DELIVERED",
          "COMPLETED",
          "CANCELLED"
        ],
        "title": "OrderStatus"
      },
      "RateOrderRequest": {
        "properties": {
          "stars": {
            "type": "integer",
            "maximum": 5.0,
            "minimum": 1.0,
            "title": "Stars"
          }
        },
        "type": "object",
        "required": [
          "stars"
        ],
        "title": "RateOrderRequest"
      },
      "RatingResponse": {
        "properties": {
          "order_id": {
            "type": "string",
            "title": "Order Id"
          },
          "rater_id": {
            "type": "string",
            "title": "Rater Id"
          },
          "ratee_id": {
            "type": "string",
            "title": "Ratee Id"
          },
          "stars": {
            "type": "integer",
            "title": "Stars"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "order_id",
          "rater_id",
          "ratee_id",
          "stars",
          "created_at"
        ],
        "title": "RatingResponse"
      },
      "RegisterRequest": {
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "title": "Email"
          },
          "password": {
            "type": "string",
            "minLength": 6,
            "title": "Password"
          },
          "name": {
            "type": "string",
            "maxLength": 50,
            "minLength": 1,
            "title": "Name"
          }
        },
        "type": "object",
        "required": [
          "email",
          "password",
          "name"
        ],
        "title": "RegisterRequest"
      },
      "TokenResponse": {
        "properties": {
          "access_token": {
            "type": "string",
            "title": "Access Token"
          },
          "token_type": {
            "type": "string",
            "title": "Token Type",
            "default": "bearer"
          }
        },
        "type": "object",
        "required": [
          "access_token"
        ],
        "title": "TokenResponse"
      },
      "UserRatingResponse": {
        "properties": {
          "user_id": {
            "type": "string",
            "title": "User Id"
          },
          "average": {
            "type": "number",
            "title": "Average"
          },
          "count": {
            "type": "integer",
            "title": "Count"
          }
        },
        "type": "object",
        "required": [
          "user_id",
          "average",
          "count"
        ],
        "title": "UserRatingResponse"
      },
      "UserResponse": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "email": {
            "type": "string",
            "format": "email",
            "title": "Email"
          },
          "name": {
            "type": "string",
            "title": "Name"
          }
        },
        "type": "object",
        "required": [
          "id",
          "email",
          "name"
        ],
        "title": "UserResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    },
    "securitySchemes": {
      "OAuth2PasswordBearer": {
        "type": "oauth2",
        "flows": {
          "password": {
            "scopes": {},
            "tokenUrl": "/auth/login"
          }
        }
      }
    }
  }
}
